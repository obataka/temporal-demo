# Google AI Studio で取得: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# リトライ検証モード（1にすると Activity が意図的に失敗する）
DEBUG_FAIL=0

# ── 問い合わせフォーム通知 (web-ui /api/contact) ──────────────────────────────
# 未設定の場合は受付ログのみ記録し、メール送信をスキップして正常応答を返します。
NOTIFICATION_EMAIL=your-inbox@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-password
# 省略時は SMTP_USER がそのまま送信元アドレスになります
FROM_EMAIL=noreply@example.com

# ── Postgres / Grafana（ローカル開発用デフォルト値。本番では必ず変更すること）─────
POSTGRES_PASSWORD=pgLocalDev_7f3a
GRAFANA_ADMIN_PASSWORD=grafanaLocalDev_9c1e
