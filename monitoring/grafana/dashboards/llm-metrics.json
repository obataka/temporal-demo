{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "templating": {
    "list": [
      {
        "name": "price_gemini_flash_in",
        "type": "textbox",
        "label": "Gemini 2.5 Flash In ($/M tokens)",
        "current": { "selected": false, "text": "0.30", "value": "0.30" },
        "hide": 0,
        "options": [],
        "query": "0.30",
        "skipUrlSync": false
      },
      {
        "name": "price_gemini_flash_out",
        "type": "textbox",
        "label": "Gemini 2.5 Flash Out ($/M tokens)",
        "current": { "selected": false, "text": "2.50", "value": "2.50" },
        "hide": 0,
        "options": [],
        "query": "2.50",
        "skipUrlSync": false
      },
      {
        "name": "price_mock_in",
        "type": "textbox",
        "label": "Mock LLM In ($/M tokens)",
        "current": { "selected": false, "text": "0.100", "value": "0.100" },
        "hide": 0,
        "options": [],
        "query": "0.100",
        "skipUrlSync": false
      },
      {
        "name": "price_mock_out",
        "type": "textbox",
        "label": "Mock LLM Out ($/M tokens)",
        "current": { "selected": false, "text": "0.100", "value": "0.100" },
        "hide": 0,
        "options": [],
        "query": "0.100",
        "skipUrlSync": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Cumulative Token Consumption",
      "description": "Total number of LLM tokens consumed since worker startup (input + output, all models). Resets on worker restart.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 10000 },
              { "color": "red",    "value": 100000 }
            ]
          },
          "unit": "short",
          "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(llm_tokens_total)",
          "instant": true,
          "refId": "A",
          "legendFormat": "Total Tokens"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Real-time Operational Expenditures (OpEx)",
      "description": "Estimated cumulative cost in USD since worker startup. Unit prices are overridable via Variables at the top of this dashboard (default: Gemini 2.5 Flash at $0.30/$2.50 per 1M tokens).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red",    "value": 0.10 }
            ]
          },
          "unit": "currencyUSD",
          "decimals": 6,
          "noValue": "$0.000000"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(\n  sum(llm_tokens_total{model=\"gemini-2.5-flash\", type=\"input\"})  * ${price_gemini_flash_in} +\n  sum(llm_tokens_total{model=\"gemini-2.5-flash\", type=\"output\"}) * ${price_gemini_flash_out} +\n  sum(llm_tokens_total{model=\"mock-llm-v1\",       type=\"input\"})  * ${price_mock_in} +\n  sum(llm_tokens_total{model=\"mock-llm-v1\",       type=\"output\"}) * ${price_mock_out}\n) / 1000000",
          "instant": true,
          "refId": "A",
          "legendFormat": "Estimated Cost"
        }
      ]
    },
    {
      "id": 6,
      "type": "piechart",
      "title": "OpEx by Model — Cost Attribution",
      "description": "Per-model share of total estimated expenditure. Models with no recorded tokens appear as $0.000000. Pricing sourced from llm_price_per_million_tokens Gauge (see docs/costs.md).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed" },
          "unit": "currencyUSD",
          "decimals": 6,
          "min": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "gemini-2.5-flash" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#1A73E8", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "gemini-2.0-flash" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#34A853", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "mock-llm-v1" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#FBBC05", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "pieType": "donut",
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": ["value", "percent"]
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(model) (\n  (llm_tokens_total * on(model, type) group_left() llm_price_per_million_tokens)\n  or\n  (llm_price_per_million_tokens * 0)\n) / 1000000",
          "instant": true,
          "refId": "A",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Inference Latency — 5-Minute Rolling Average",
      "description": "Average end-to-end LLM inference latency per model over a 5-minute sliding window. Computed via rate(sum) / rate(count) on the Histogram metric. Spikes indicate API throttling or network congestion.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(llm_inference_latency_seconds_sum[5m]) / rate(llm_inference_latency_seconds_count[5m])",
          "refId": "A",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Cumulative OpEx Over Time — Per Model (USD)",
      "description": "Running total of estimated expenditure per model over the selected time window. An ever-increasing staircase curve is expected for active workflows. Flat segments indicate idle periods.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "currencyUSD",
          "decimals": 6,
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(model) (llm_tokens_total * on(model, type) group_left() llm_price_per_million_tokens) / 1000000",
          "refId": "A",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Token Throughput — Input & Output Rate (tokens/min)",
      "description": "Real-time token consumption rate per model and token type (input/output). Useful for detecting burst traffic and forecasting API quota headroom. Based on a 5-minute rate window × 60.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(llm_tokens_total[5m]) * 60",
          "refId": "A",
          "legendFormat": "{{model}} / {{type}}"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["llm", "temporal", "ai-agent", "observability"],
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "The Immortal AI Agent — LLM Observability",
  "uid": "llm-metrics-v1",
  "version": 3
}
